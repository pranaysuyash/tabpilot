-            VStack(alignment: .leading, spacing: 2) {
-                Text(tab.title)
-                    .font(.subheadline)
-                    .lineLimit(1)
-                Text("Window \(tab.windowId) • Tab \(tab.tabIndex)")
-                    .font(.caption2)
-                    .foregroundStyle(.secondary)
